# Copy to .env and fill in real values. .env is gitignored and auto-loaded by
# the justfile (so every recipe sees these vars).

# Remote k3s node for `just upload-*` and `just up` (image streaming target).
BALVIBOT_K3S_NODE=user@host

# Hermes-agent secrets (see `just bootstrap-secrets`).
# BALVIBOT_API_SERVER_KEY is required; set at least one of the provider keys below.
BALVIBOT_API_SERVER_KEY=
BALVIBOT_ANTHROPIC_API_KEY=
BALVIBOT_OPENAI_API_KEY=

# Postgres password (URL-safe). Used for the postgres-secrets Secret and woven
# into the DATABASE_URL stored in api-secrets.
BALVIBOT_POSTGRES_PASSWORD=

# ProtonMail Bridge IMAP creds for the mail indexer (from `bridge info` inside
# the protonmail-bridge pod).
BALVIBOT_IMAP_USER=
BALVIBOT_IMAP_PASS=

# Bearer token agents present when calling the api MCP server (grantees + mail
# + docs tools).
BALVIBOT_API_MCP_TOKEN=

# Path to a Google Cloud service-account JSON keyfile. Mounted into the
# iron-proxy pod for its gcp_auth transform, which mints OAuth access
# tokens for gdocs-indexer's Drive egress. gdocs-indexer never sees this
# file or the tokens it produces.
BALVIBOT_GCP_SA_KEY_FILE=
