# Copy to .env and fill in real values. .env is gitignored and auto-loaded by
# the justfile (so every recipe sees these vars).

# Remote k3s node for `just upload-*` and `just up` (image streaming target).
PHILOS_K3S_NODE=user@host

# Hermes-agent secrets (see `just bootstrap-secrets`).
# PHILOS_API_SERVER_KEY is required; set at least one of the provider keys below.
PHILOS_API_SERVER_KEY=
PHILOS_ANTHROPIC_API_KEY=
PHILOS_OPENAI_API_KEY=

# ProtonMail Bridge IMAP creds for mail-indexer (from `bridge info` inside the
# protonmail-bridge pod).
PHILOS_IMAP_USER=
PHILOS_IMAP_PASS=

# Bearer token agents present when calling the mail-indexer MCP server.
PHILOS_MAIL_INDEXER_MCP_TOKEN=

# Bearer token agents present when calling the gdocs-indexer MCP server.
PHILOS_GDOCS_INDEXER_MCP_TOKEN=

# Path to a Google Cloud service-account JSON keyfile. Mounted into the
# iron-proxy pod for its gcp_auth transform, which mints OAuth access
# tokens for gdocs-indexer's Drive egress. gdocs-indexer never sees this
# file or the tokens it produces.
PHILOS_GCP_SA_KEY_FILE=
